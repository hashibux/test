generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMPANY
  RECOMMENDER
  ADMIN
}

model User {
  id    String @id @default(cuid())
  email String @unique
  role  Role
}

model Job {
  id          String @id @default(cuid())
  title       String
  description String
  salaryMin   Int?
  salaryMax   Int?
  createdAt   DateTime @default(now())
}
